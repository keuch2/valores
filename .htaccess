# ============================================================================
#  Valores CMS — .htaccess raíz
#  Front-controller + friendly URLs + cabeceras de seguridad
#
#  PORTABLE: funciona sin importar en qué subcarpeta se sirva la app
#  (local: /valores-app/  ·  producción: /valores/). No hardcodea la ruta base:
#  RewriteBase se infiere y los bloqueos usan reglas relativas.
# ============================================================================

# --- Cabeceras de seguridad ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # CSP básica (ajustar cuando se conozcan todos los orígenes de assets/CDN)
    Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; script-src 'self' 'unsafe-inline' https:; font-src 'self' https: data:; frame-ancestors 'self';"
</IfModule>

# --- No listar directorios ---
Options -Indexes

# --- Front-controller / friendly URLs ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Sin RewriteBase: Apache infiere la base del directorio del .htaccess,
    # así el mismo archivo sirve en cualquier subcarpeta.

    # Bloquear carpetas internas (defensa en profundidad; además cada una trae
    # su propio .htaccess "Deny from all"). Relativo a la base de la app.
    RewriteRule ^(includes|database|config)(/|$) - [F]

    # No reescribir el panel admin (tiene su propio router)
    RewriteRule ^admin(/.*)?$ - [L]

    # Servir archivos y directorios existentes tal cual (assets, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás al front-controller público
    RewriteRule ^ index.php [L]
</IfModule>
